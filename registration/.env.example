VITE_GAS_WEB_APP_URL=https://script.google.com/macros/s/PASTE_YOUR_DEPLOYMENT_ID/exec

# REQUIRED for Vercel production (both register + certificate projects):
# 1. Vercel Dashboard → your project → Settings → Environment Variables
# 2. Add: VITE_GAS_WEB_APP_URL = https://script.google.com/macros/s/YOUR_ID/exec
# 3. Enable for Production (and Preview if needed)
# 4. Redeploy the project (Deployments → ... → Redeploy)
#
# Local .env is NOT uploaded to Vercel — you must set this in Vercel separately.
# You can also use GAS_WEB_APP_URL instead of VITE_GAS_WEB_APP_URL on Vercel.

# Google Form URL for post-webinar feedback (shown on registration success and e-cert pages)
# Dunong Feedback and Evaluation Form
VITE_GOOGLE_FORM_URL=https://docs.google.com/forms/d/1JRrFNtUlLU9_W64G8TjXSnhTxGzGcOiU8ps0EhWilFc/viewform

# App mode for split Vercel deployments: register | certificate | both (default)
# register    — before webinar (registration only)
# certificate — after webinar (e-certificate only; set CERTIFICATE_PAGE_URL in Apps Script to this URL)
VITE_APP_MODE=both
