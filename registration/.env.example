VITE_GAS_WEB_APP_URL=https://script.google.com/macros/s/PASTE_YOUR_DEPLOYMENT_ID/exec

# Google Form URL for post-webinar feedback (shown on registration success and e-cert pages)
VITE_GOOGLE_FORM_URL=https://docs.google.com/forms/d/PASTE_YOUR_FORM_ID/viewform

# App mode for split Vercel deployments: register | certificate | both (default)
# register    — before webinar (registration only)
# certificate — after webinar (e-certificate only; set CERTIFICATE_PAGE_URL in Apps Script to this URL)
VITE_APP_MODE=both
